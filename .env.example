# ─── Notion ───────────────────────────────────────────────────────────────────
# Get from https://www.notion.so/my-integrations
VITE_NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Dissertation Workspace Database IDs
VITE_NOTION_CHAPTER_DB=78202be3-8fe8-4e7d-9662-98edfb212068
VITE_NOTION_UPDATELOG_DB=402192b1-8b6b-4dbc-908c-48004b46b639

# VOW Center Workspace Database IDs
VITE_NOTION_PROGRAMS_DB=b2f6651a-0d61-4b2e-a5d8-41375d523227
VITE_NOTION_MILESTONES_DB=f7be4254-ddd3-415f-b96e-5a78ee6431b3
VITE_NOTION_GRANTS_DB=b665c657-55ea-4074-852a-07d17e629b81
VITE_NOTION_COMMENTS_DB=068cda99-c5d6-4747-8b92-b9a9654eec5b

# ─── Anthropic ────────────────────────────────────────────────────────────────
# Get from https://console.anthropic.com/
# NOTE: For production, move this to a Vercel serverless function (api/chat.js)
# so the key is never exposed in the browser bundle.
VITE_ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ─── Auth ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed admin emails
VITE_ADMIN_EMAILS=your@email.com

# Comma-separated list of allowed collaborator emails (dissertation chair, etc.)
# Format: email:role  e.g. chair@hampton.edu:chair,committee@hampton.edu:committee
VITE_COLLABORATOR_EMAILS=

# ─── App ──────────────────────────────────────────────────────────────────────
VITE_APP_TITLE=Dissertation Dashboard
VITE_APP_URL=http://localhost:5173
